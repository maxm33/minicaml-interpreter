letrec search(elem lis count) =
    if (List.isEmpty lis) then -1
    else let head = List.head lis in
        if op(head == elem) then count
        else apply(search elem List.remove lis op(count + 1) ;) ;;

let list1 = [ 11,5,21,5,1,2 ] ;;
let list2 = [ 11,2 ] ;;
let list3 = List.append list1 list2 ;;

apply(search 21 list1 0 ;) ;;